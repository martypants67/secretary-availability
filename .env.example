# Email of the secretary's calendar (the "primary" calendar of this account is queried).
SECRETARY_EMAIL=secretary@yourclinic.example
# Path to the service account JSON key (relative to project root or absolute).
GOOGLE_APPLICATION_CREDENTIALS=./config/service-account.json
# IANA timezone of the clinic. Free slots are computed in this timezone.
# Examples: Europe/London, America/New_York, Australia/Sydney
TIMEZONE=Europe/London
# Working window (24h, local clinic time).
WORK_START_HOUR=9
WORK_END_HOUR=17
# Days of the week considered working days (1=Mon ... 7=Sun, ISO).
WORK_DAYS=1,2,3,4,5
# How many calendar days ahead to compute availability for.
DAYS_AHEAD=14
# Minimum slot length to display, in minutes. Free gaps shorter than this are dropped.
MIN_SLOT_MINUTES=15
# Cache TTL in seconds for freebusy responses.
CACHE_TTL_SECONDS=120
# HTTP port.
PORT=3000
# Comma-separated list of origins allowed to embed the widget (CORS).
# Use * for any origin while testing.
ALLOWED_ORIGINS=*
